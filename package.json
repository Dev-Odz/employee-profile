		"db:seed:initial": "npx sequelize-cli db:seed --seed initialdata.js",
		"reset:seed": "del .seeded",
		"start:local": "node wait-for-db.js && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all && npm run dev"
	},
